//   WS_MINIMIZEBOX(0x00020000) | WS_MAXIMIZEBOX(0x00010000)
1902 DIALOGEX 0, 0, 320, 230
STYLE 0x80CF0840
CAPTION "MTCL Komponenten"
FONT 8, "MS Shell Dlg"
BEGIN
